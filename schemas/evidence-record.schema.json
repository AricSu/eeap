{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eeap.dev/schemas/evidence-record.schema.json",
  "title": "EvidenceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidenceId",
    "executionId",
    "kind",
    "recordedAt"
  ],
  "properties": {
    "evidenceId": {
      "type": "string",
      "minLength": 1
    },
    "executionId": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "data": {
      "type": "object"
    },
    "sourceRef": {
      "type": "string"
    }
  }
}
