{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eeap.dev/schemas/execution-event.schema.json",
  "title": "ExecutionEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "executionId",
    "type",
    "at"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "executionId": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "requested",
        "acknowledged",
        "completed",
        "failed",
        "evidence_recorded"
      ]
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "evidenceIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
