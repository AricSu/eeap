{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eeap.dev/schemas/capability-descriptor.schema.json",
  "title": "CapabilityDescriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "inputSchema"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "inputSchema": {
      "type": "object"
    },
    "outputSchema": {
      "type": "object"
    },
    "evidenceModes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "completionMode": {
      "type": "string",
      "enum": [
        "accepted_only",
        "readback_confirmed",
        "observed_effect"
      ]
    },
    "idempotent": {
      "type": "boolean"
    }
  }
}
